# Redmine server URL
REDMINE_URL=https://redmine.example.com

# API Key authentication (optional)
REDMINE_API_KEY=your-api-key-here

# Basic authentication (optional)
# REDMINE_USERNAME=your-username
# REDMINE_PASSWORD=your-password

# You can set API key, basic auth, or both. If both are set,
# the server will send X-Redmine-API-Key and Basic Authorization headers.

# Optional
# MAX_TOKENS=50000
# PREFIX=redmine_
# ENABLE_TOOLSETS=all

